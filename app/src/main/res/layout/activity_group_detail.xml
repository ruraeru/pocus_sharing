<?xml version="1.0" encoding="utf-8"?>
<!-- GroupDetailActivity의 메인 레이아웃: 그룹 상세 정보와 멤버들의 실시간 상태를 표시 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 상단 툴바: 그룹 이름과 관리 버튼 포함 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:title="그룹 상세">

        <!-- 그룹 관리 버튼 (관리자에게만 보임) -->
        <ImageButton
            android:id="@+id/btn_manage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            android:visibility="gone" />

    </androidx.appcompat.widget.Toolbar>

    <!-- 초대 코드 표시 영역 -->
    <LinearLayout
        android:id="@+id/ll_invite_code_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_rounded_gray"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="초대 코드: "
            android:textColor="@color/text_gray"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_group_code_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="-"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/text_gray" />
    </LinearLayout>

    <!-- 집중/휴식 상태 전환 라디오 그룹 -->
    <RadioGroup
        android:id="@+id/rg_personal_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_invite_code_container">

        <RadioButton
            android:id="@+id/rb_personal_focus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/selector_radio_focus"
            android:checked="true"
            android:text="@string/focus"
            android:textColor="@color/selector_radio_focus" />

        <RadioButton
            android:id="@+id/rb_personal_rest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:buttonTint="@color/selector_radio_rest"
            android:text="@string/rest"
            android:textColor="@color/selector_radio_rest" />

    </RadioGroup>

    <!-- 중앙 원형 타이머 뷰 -->
    <com.example.pocussharing.TimerView
        android:id="@+id/personal_timer_view"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rg_personal_status" />

    <!-- 디지털 타이머 텍스트 -->
    <TextView
        android:id="@+id/tv_personal_digital_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="00:00:00"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/personal_timer_view" />

    <!-- 그룹 멤버 리스트 (RecyclerView) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_members"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_personal_digital_timer" />

</androidx.constraintlayout.widget.ConstraintLayout>