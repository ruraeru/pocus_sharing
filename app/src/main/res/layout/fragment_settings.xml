<?xml version="1.0" encoding="utf-8"?>
<!-- SettingsFragment 레이아웃: 프로필 관리 및 앱 설정 항목 포함 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">

    <!-- 화면 제목 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="설정"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 사용자 프로필 이미지 표시 -->
    <ImageView
        android:id="@+id/iv_profile"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/circle_gray"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- 사용자 닉네임 표시 -->
    <TextView
        android:id="@+id/tv_nickname_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="사용자 이름"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/iv_profile"
        app:layout_constraintStart_toEndOf="@id/iv_profile"
        app:layout_constraintTop_toTopOf="@id/iv_profile" />

    <!-- 닉네임 변경 입력 라벨 -->
    <TextView
        android:id="@+id/tv_nickname_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="닉네임 변경"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_profile" />

    <!-- 닉네임 입력 필드 -->
    <EditText
        android:id="@+id/et_nickname"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="닉네임을 입력하세요"
        app:layout_constraintEnd_toStartOf="@id/btn_save_nickname"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_nickname_label" />

    <!-- 닉네임 저장 버튼 -->
    <Button
        android:id="@+id/btn_save_nickname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="저장"
        app:layout_constraintBottom_toBottomOf="@id/et_nickname"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/et_nickname" />

    <!-- 앱 공통 설정 섹션 라벨 -->
    <TextView
        android:id="@+id/tv_app_settings_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="앱 설정"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_nickname" />

    <!-- 알람 끄기 옵션 스위치 -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_alarm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="알람 끄기"
        app:layout_constraintTop_toBottomOf="@id/tv_app_settings_label" />

    <!-- 화면 꺼짐 방지 옵션 스위치 -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_screen_on"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="화면 꺼짐 방지"
        app:layout_constraintTop_toBottomOf="@id/switch_alarm" />

    <!-- 앱 나가기 방지 옵션 스위치 -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_app_exit_prevention"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="앱 나가기 방지"
        app:layout_constraintTop_toBottomOf="@id/switch_screen_on" />

    <!-- 로그아웃 버튼 -->
    <Button
        android:id="@+id/btn_logout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:backgroundTint="@color/text_gray"
        android:text="로그아웃"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/switch_app_exit_prevention" />

</androidx.constraintlayout.widget.ConstraintLayout>